NODE_ENV=production
DOMAIN=pro.example.com
APP_URL=https://pro.example.com

# Security — GENERATE YOUR OWN SECRETS (e.g. openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
COOKIE_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Database
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
DATABASE_URL=postgresql://hideyoupro:CHANGE_ME@postgres:5432/hideyoupro
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
REDIS_URL=redis://:CHANGE_ME@redis:6379

# VPN backend (REMNAWAVE)
REMNAWAVE_URL=
REMNAWAVE_TOKEN=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# Payment: YuKassa
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_RETURN_URL=https://pro.example.com/dashboard/payment-success

# Payment: CryptoPay
CRYPTOPAY_API_TOKEN=
CRYPTOPAY_NETWORK=mainnet

# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Feature flags
FEATURE_CRYPTO_PAYMENTS=true
FEATURE_REFERRAL=true
FEATURE_EMAIL_AUTH=true
FEATURE_TELEGRAM_AUTH=true
FEATURE_TRIAL=false
TRIAL_DAYS=3
FEATURE_GIFTS=true
FEATURE_BALANCE=true

# Referral settings
REFERRAL_BONUS_DAYS=30
REFERRAL_MIN_DAYS=30
REFERRAL_REWARD_TYPE=days
REFERRAL_REWARD_AMOUNT=100

LOG_LEVEL=info
